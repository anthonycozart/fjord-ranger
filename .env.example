# Copy this file to .env and fill in real values.
# .env is git-ignored and never committed.

# Database (use DATABASE_PUBLIC_URL from Railway for local dev)
DATABASE_URL=postgresql://postgres:...@monorail.proxy.rlwy.net:PORT/railway

# Twilio (from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Anthropic (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Admin alerts go to this number (your personal cell)
ADMIN_PHONE_NUMBER=+1xxxxxxxxxx

# Signup keyword for invite-only onboarding
SIGNUP_KEYWORD=RANGER
